# ─────────────────────────────────────────────────────────────
# Urbanix — Variables de entorno
# Copia este archivo a `.env` y rellena con los datos de tu
# proyecto de Supabase (Project Settings → API).
# NUNCA subas el archivo `.env` al repositorio.
# ─────────────────────────────────────────────────────────────

# URL del proyecto Supabase (ej: https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Clave pública "anon" (segura para el cliente; las políticas RLS protegen los datos)
VITE_SUPABASE_ANON_KEY=

# Nombre del bucket de Storage para planos y excels (debe coincidir con la migración SQL)
VITE_SUPABASE_BUCKET=urbanix-files
